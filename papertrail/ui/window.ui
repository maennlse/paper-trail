<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="Adw" version="1.0"/>

  <template class="PaperTrailWindow" parent="AdwApplicationWindow">
    <property name="default-width">1320</property>
    <property name="default-height">860</property>
    <property name="title">Paper Trail</property>
    <property name="content">
      <object class="GtkBox" id="main_paned">
        <property name="orientation">horizontal</property>
        <property name="css-classes">main-split</property>

        <child>
          <object class="GtkBox" id="sidebar_panel">
            <property name="orientation">vertical</property>
            <property name="width-request">300</property>
            <property name="hexpand">False</property>
            <property name="halign">start</property>
            <property name="css-classes">sidebar-panel sidebar-root</property>

            <child>
              <object class="AdwHeaderBar">
                <property name="show-start-title-buttons">False</property>
                <property name="show-end-title-buttons">False</property>
                <property name="css-classes">sidebar-surface sidebar-header</property>
                <child type="title">
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">2</property>
                    <child>
                      <object class="GtkLabel" id="sidebar_title_label">
                        <property name="xalign">0.5</property>
                        <style>
                          <class name="title"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="sidebar_subtitle_label">
                        <property name="xalign">0.5</property>
                        <style>
                          <class name="caption"/>
                          <class name="dim-label"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
                <child type="end">
                  <object class="GtkButton" id="sidebar_search_button">
                    <property name="icon-name">system-search-symbolic</property>
                    <property name="tooltip-text">Search Notes</property>
                    <property name="css-classes">flat</property>
                  </object>
                </child>
              </object>
            </child>

            <child>
              <object class="GtkRevealer" id="sidebar_search_revealer">
                <property name="transition-type">slide-down</property>
                <property name="child">
                  <object class="GtkBox" id="sidebar_search_box">
                    <property name="css-classes">sidebar-surface sidebar-search-box</property>
                    <property name="margin-top">8</property>
                    <property name="margin-bottom">8</property>
                    <property name="margin-start">12</property>
                    <property name="margin-end">12</property>
                    <child>
                      <object class="GtkSearchEntry" id="sidebar_search_entry">
                        <property name="hexpand">True</property>
                        <property name="css-classes">sidebar-search-entry</property>
                        <property name="placeholder-text">Search notes</property>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>

            <child>
              <object class="GtkBox" id="sidebar_body">
                <property name="orientation">horizontal</property>
                <property name="vexpand">True</property>
                <property name="css-classes">sidebar-surface sidebar-body sidebar-body-surface</property>
                <child>
                  <object class="GtkBox" id="sidebar_folders_column">
                    <property name="orientation">vertical</property>
                    <property name="width-request">52</property>
                    <property name="hexpand">False</property>
                    <property name="vexpand">True</property>
                    <property name="css-classes">sidebar-surface sidebar-folders-column</property>
                    <child>
                      <object class="GtkScrolledWindow" id="sidebar_folders_scroller">
                        <property name="width-request">52</property>
                        <property name="hexpand">False</property>
                        <property name="min-content-width">52</property>
                        <property name="max-content-width">52</property>
                        <property name="vexpand">True</property>
                        <property name="has-frame">False</property>
                        <property name="hscrollbar-policy">never</property>
                        <property name="css-classes">sidebar-surface sidebar-scroll sidebar-folders-scroller</property>
                        <child>
                          <object class="GtkViewport" id="sidebar_folders_viewport">
                            <property name="css-classes">sidebar-surface sidebar-folders-viewport</property>
                            <child>
                              <object class="GtkBox" id="sidebar_folders_content">
                                <property name="orientation">vertical</property>
                                <child>
                                  <object class="GtkBox" id="folder_list">
                                    <property name="orientation">vertical</property>
                                    <property name="css-classes">sidebar-folder-list</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox" id="sidebar_inline_add_box">
                                    <property name="orientation">vertical</property>
                                    <property name="hexpand">True</property>
                                    <property name="visible">False</property>
                                    <property name="css-classes">sidebar-surface sidebar-folder-add-box</property>
                                    <child>
                                      <object class="GtkButton" id="sidebar_inline_add_folder_button">
                                        <property name="icon-name">list-add-symbolic</property>
                                        <property name="tooltip-text">Add Folder</property>
                                        <property name="has-frame">False</property>
                                        <property name="halign">center</property>
                                        <property name="valign">center</property>
                                        <property name="focusable">False</property>
                                        <property name="focus-on-click">False</property>
                                        <property name="css-classes">flat</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox" id="sidebar_folder_add_box">
                        <property name="orientation">vertical</property>
                        <property name="hexpand">True</property>
                        <property name="css-classes">sidebar-surface sidebar-folder-add-box</property>
                        <child>
                          <object class="GtkButton" id="sidebar_add_folder_button">
                            <property name="icon-name">list-add-symbolic</property>
                            <property name="tooltip-text">Add Folder</property>
                            <property name="has-frame">False</property>
                            <property name="halign">center</property>
                            <property name="valign">center</property>
                            <property name="focusable">False</property>
                            <property name="focus-on-click">False</property>
                            <property name="css-classes">flat</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkSeparator" id="folders_divider">
                    <property name="orientation">vertical</property>
                    <property name="css-classes">sidebar-divider folders-divider</property>
                  </object>
                </child>
                <child>
                  <object class="GtkScrolledWindow" id="sidebar_notes_scroller">
                    <property name="vexpand">True</property>
                    <property name="has-frame">False</property>
                    <property name="hscrollbar-policy">never</property>
                    <property name="css-classes">sidebar-surface sidebar-scroll sidebar-notes-scroller</property>
                    <child>
                      <object class="GtkViewport" id="sidebar_notes_viewport">
                        <property name="css-classes">sidebar-surface sidebar-notes-viewport</property>
                        <child>
                          <object class="GtkBox" id="note_list">
                            <property name="orientation">vertical</property>
                            <property name="css-classes">sidebar-note-list</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkSeparator" id="sidebar_divider">
            <property name="orientation">vertical</property>
            <property name="css-classes">sidebar-divider</property>
          </object>
        </child>

        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="hexpand">True</property>
            <property name="vexpand">True</property>

            <child>
              <object class="AdwHeaderBar">
                <child type="start">
                  <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">6</property>
                    <child>
                      <object class="GtkButton">
                        <property name="icon-name">sidebar-show-symbolic</property>
                        <property name="tooltip-text">Toggle Notes Sidebar</property>
                        <property name="action-name">win.toggle-sidebar</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton">
                        <property name="icon-name">list-add-symbolic</property>
                        <property name="tooltip-text">New Note</property>
                        <property name="action-name">win.new-note</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child type="title">
                  <object class="GtkBox" id="title_box">
                    <property name="orientation">vertical</property>
                    <property name="spacing">2</property>
                    <child>
                      <object class="GtkLabel" id="editor_title_label">
                        <property name="hexpand">True</property>
                        <property name="xalign">0.5</property>
                        <property name="ellipsize">end</property>
                        <style>
                          <class name="title"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="editor_filename_label">
                        <property name="hexpand">True</property>
                        <property name="xalign">0.5</property>
                        <property name="ellipsize">end</property>
                        <style>
                          <class name="caption"/>
                          <class name="dim-label"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
                <child type="end">
                  <object class="GtkMenuButton" id="notes_menu_button">
                    <property name="icon-name">open-menu-symbolic</property>
                    <property name="tooltip-text">Menu</property>
                  </object>
                </child>
                <child type="end">
                  <object class="GtkToggleButton" id="info_button">
                    <property name="icon-name">info-outline-symbolic</property>
                    <property name="tooltip-text">Document Properties</property>
                    <property name="action-name">win.toggle-info</property>
                  </object>
                </child>
              </object>
            </child>

            <child>
              <object class="GtkBox">
                <property name="orientation">horizontal</property>
                <property name="hexpand">True</property>
                <property name="vexpand">True</property>

                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="hexpand">True</property>
                    <property name="vexpand">True</property>

                    <child>
                      <object class="GtkRevealer" id="editor_search_revealer">
                        <property name="transition-type">slide-down</property>
                        <property name="child">
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">8</property>
                            <property name="margin-top">10</property>
                            <property name="margin-bottom">10</property>
                            <property name="margin-start">12</property>
                            <property name="margin-end">12</property>

                            <child>
                              <object class="GtkBox">
                                <property name="orientation">horizontal</property>
                                <property name="spacing">8</property>
                                <child>
                                  <object class="GtkSearchEntry" id="editor_search_entry">
                                    <property name="hexpand">True</property>
                                    <property name="placeholder-text">Find in current note</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="editor_search_status_label">
                                    <property name="width-request">120</property>
                                    <property name="xalign">0</property>
                                    <style>
                                      <class name="caption"/>
                                      <class name="dim-label"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton">
                                    <property name="icon-name">go-up-symbolic</property>
                                    <property name="tooltip-text">Previous Match</property>
                                    <property name="action-name">win.find-previous</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton">
                                    <property name="icon-name">go-down-symbolic</property>
                                    <property name="tooltip-text">Next Match</property>
                                    <property name="action-name">win.find-next</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkToggleButton" id="editor_replace_toggle_button">
                                    <property name="label">Replace</property>
                                    <property name="action-name">win.toggle-replace</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton">
                                    <property name="icon-name">window-close-symbolic</property>
                                    <property name="tooltip-text">Close Search</property>
                                    <property name="action-name">win.close-search</property>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <child>
                              <object class="GtkRevealer" id="editor_replace_revealer">
                                <property name="transition-type">slide-down</property>
                                <property name="child">
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">8</property>
                                    <child>
                                      <object class="GtkEntry" id="editor_replace_entry">
                                        <property name="hexpand">True</property>
                                        <property name="placeholder-text">Replace with</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkButton">
                                        <property name="label">Replace</property>
                                        <property name="tooltip-text">Replace Current Match</property>
                                        <property name="action-name">win.replace-current</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkButton">
                                        <property name="label">Replace All</property>
                                        <property name="tooltip-text">Replace All Matches</property>
                                        <property name="action-name">win.replace-all</property>
                                      </object>
                                    </child>
                                  </object>
                                </property>
                              </object>
                            </child>
                          </object>
                        </property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkStack" id="editor_stack">
                        <property name="hexpand">True</property>
                        <property name="vexpand">True</property>
                        <child>
                          <object class="GtkScrolledWindow" id="empty_page">
                            <property name="hexpand">True</property>
                            <property name="vexpand">True</property>
                            <property name="hscrollbar-policy">never</property>
                            <child>
                              <object class="GtkViewport">
                                <child>
                                  <object class="GtkStack" id="empty_state_stack">
                                    <property name="hexpand">True</property>
                                    <property name="vexpand">True</property>
                                    <child>
                                      <object class="GtkBox" id="recent_notes_page">
                                        <property name="orientation">vertical</property>
                                        <property name="spacing">18</property>
                                        <property name="margin-top">28</property>
                                        <property name="margin-bottom">28</property>
                                        <property name="margin-start">28</property>
                                        <property name="margin-end">28</property>
                                        <child>
                                          <object class="GtkBox">
                                            <property name="orientation">vertical</property>
                                            <property name="spacing">4</property>
                                            <child>
                                              <object class="GtkLabel">
                                                <property name="xalign">0</property>
                                                <property name="label">Recent Notes</property>
                                                <style>
                                                  <class name="title-2"/>
                                                </style>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkLabel" id="recent_notes_subtitle_label">
                                                <property name="xalign">0</property>
                                                <property name="wrap">True</property>
                                                <property name="label">Open one of your latest notes or create a new one.</property>
                                                <style>
                                                  <class name="dim-label"/>
                                                </style>
                                              </object>
                                            </child>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkFlowBox" id="recent_notes_grid">
                                            <property name="selection-mode">none</property>
                                            <property name="column-spacing">16</property>
                                            <property name="row-spacing">16</property>
                                            <property name="max-children-per-line">3</property>
                                            <property name="min-children-per-line">3</property>
                                            <property name="homogeneous">True</property>
                                            <property name="css-classes">recent-notes-grid</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkBox" id="empty_folder_page">
                                        <property name="orientation">vertical</property>
                                        <property name="spacing">24</property>
                                        <property name="halign">center</property>
                                        <property name="valign">center</property>
                                        <property name="hexpand">True</property>
                                        <property name="vexpand">True</property>
                                        <property name="margin-top">28</property>
                                        <property name="margin-bottom">28</property>
                                        <property name="margin-start">28</property>
                                        <property name="margin-end">28</property>
                                        <property name="width-request">360</property>
                                        <property name="css-classes">empty-folder-page</property>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label">Get started</property>
                                            <property name="justify">center</property>
                                            <property name="wrap">True</property>
                                            <style>
                                              <class name="title-1"/>
                                            </style>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkButton" id="empty_folder_new_note_button">
                                            <property name="label">New Note</property>
                                            <property name="action-name">win.new-note</property>
                                            <property name="halign">fill</property>
                                            <property name="css-classes">empty-folder-button</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkScrolledWindow" id="editor_page">
                            <property name="hexpand">True</property>
                            <property name="vexpand">True</property>
                            <property name="css-classes">editor-scroll</property>
                          </object>
                        </child>
                      </object>
                    </child>

                  </object>
                </child>

                <child>
                  <object class="GtkRevealer" id="info_revealer">
                    <property name="transition-type">slide-left</property>
                    <property name="child">
                      <object class="GtkScrolledWindow" id="info_panel">
                        <property name="css-classes">info-panel</property>
                        <property name="width-request">340</property>
                        <property name="hexpand">False</property>
                        <property name="min-content-width">260</property>
                        <property name="max-content-width">400</property>
                        <property name="propagate-natural-width">True</property>
                        <property name="hscrollbar-policy">never</property>
                        <child>
                          <object class="AdwPreferencesPage">
                            <property name="margin-top">12</property>
                            <property name="margin-bottom">12</property>
                            <property name="margin-start">12</property>
                            <property name="margin-end">12</property>

                            <child>
                              <object class="AdwPreferencesGroup">
                                <child>
                                  <object class="AdwActionRow" id="info_title_row">
                                    <property name="title">Title</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="AdwActionRow" id="info_name_row">
                                    <property name="title">File Name</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="AdwActionRow" id="info_location_row">
                                    <property name="title">Location</property>
                                    <property name="subtitle-selectable">True</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="AdwActionRow" id="info_type_row">
                                    <property name="title">Document Type</property>
                                    <child type="suffix">
                                      <object class="GtkMenuButton" id="language_popout_button">
                                        <property name="valign">center</property>
                                        <property name="icon-name">go-next-symbolic</property>
                                        <property name="tooltip-text">Choose Document Type</property>
                                        <property name="css-classes">flat</property>
                                        <property name="popover">
                                          <object class="GtkPopover" id="language_popover">
                                            <property name="has-arrow">True</property>
                                            <property name="width-request">300</property>
                                            <child>
                                              <object class="GtkBox">
                                                <property name="orientation">vertical</property>
                                                <property name="spacing">8</property>
                                                <property name="margin-top">12</property>
                                                <property name="margin-bottom">12</property>
                                                <property name="margin-start">12</property>
                                                <property name="margin-end">12</property>
                                                <child>
                                                  <object class="GtkSearchEntry" id="language_search_entry">
                                                    <property name="placeholder-text">Search languages</property>
                                                  </object>
                                                </child>
                                                <child>
                                                  <object class="GtkScrolledWindow">
                                                    <property name="min-content-height">260</property>
                                                    <property name="max-content-height">360</property>
                                                    <property name="hscrollbar-policy">never</property>
                                                    <child>
                                                      <object class="GtkListBox" id="language_listbox">
                                                        <property name="selection-mode">browse</property>
                                                        <property name="css-classes">boxed-list</property>
                                                      </object>
                                                    </child>
                                                  </object>
                                                </child>
                                              </object>
                                            </child>
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <child>
                              <object class="AdwPreferencesGroup">
                                <property name="title">Danger Zone</property>
                                <child>
                                  <object class="GtkButton" id="info_delete_button">
                                    <property name="label">Delete Note</property>
                                    <property name="halign">fill</property>
                                    <property name="valign">center</property>
                                    <property name="css-classes">destructive-action</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </template>
</interface>
